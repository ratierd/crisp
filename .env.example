# Copy to .env and fill in what you have. Everything is optional:
# the Demo model works with zero keys.

# Remote providers — a model appears in the picker only if its key is set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local provider (Ollama). Model list is discovered from the running daemon.
OLLAMA_BASE_URL=http://localhost:11434

# Observability (LangSmith). With a key set, every Run — remote, local, demo,
# stopped, failed — is traced, and thumbs up/down feedback lands on the trace.
# Without it, tracing is fully disabled.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=crisp

# Infrastructure
REDIS_URL=redis://localhost:6379
DB_PATH=./data/crisp.sqlite
PORT=3000
