# Copy to .env and fill in what you have. Everything is optional:
# the Demo model works with zero keys.

# Remote providers — a model is enabled in the picker when its key is set
# (visitors can also paste their own key in the picker: BYOK, ADR-0006).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Local models (Ollama) need no server config: the *browser* discovers and
# runs your own daemon directly (BYO, ADR-0004).

# Observability (LangSmith). With a key set, every Run — remote, local, demo,
# stopped, failed — is traced, and thumbs up/down feedback lands on the trace.
# Without it, tracing is fully disabled.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=crisp
# EU-hosted LangSmith accounts must point the SDK at the EU host:
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com

# Infrastructure
REDIS_URL=redis://localhost:6379
# The directory must be writable by the server process (created on boot).
# Containers mount a volume and set DB_PATH=/data/crisp.sqlite instead.
DB_PATH=./data/crisp.sqlite
PORT=3000

# Per-IP rate limiting (Redis-backed token buckets) is on by default.
# Set to "off" for e2e runs and local load testing.
# CRISP_RATE_LIMIT=off

# The zero-key Demo model is on by default — everywhere, the hosted instance
# included, so the Tour (ADR-0009) works with zero setup. Set "off" to force
# visitors onto a real model (OpenRouter one-click, Ollama, or a key).
# CRISP_DEMO=off
