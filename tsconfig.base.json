{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": [],
    "paths": {
      "@crisp/ai": ["./libs/ai/src/index.ts"],
      "@crisp/ai/anthropic": ["./libs/ai/src/providers/anthropic.ts"],
      "@crisp/ai/openai": ["./libs/ai/src/providers/openai.ts"],
      "@crisp/ai/openai/compatible": ["./libs/ai/src/providers/openai-compatible.ts"],
      "@crisp/ai/ollama": ["./libs/ai/src/providers/ollama.ts"],
      "@crisp/ai/client": ["./libs/ai/src/client/index.ts"],
      "@crisp/ai/vue": ["./libs/ai/src/vue/index.ts"],
      "@crisp/models": ["./libs/features/models/src/index.ts"],
      "@crisp/models/contracts": ["./libs/features/models/src/contracts.ts"],
      "@crisp/conversations": ["./libs/features/conversations/src/index.ts"],
      "@crisp/conversations/contracts": ["./libs/features/conversations/src/contracts.ts"],
      "@crisp/conversations/testing": ["./libs/features/conversations/src/testing.ts"],
      "@crisp/feedback": ["./libs/features/feedback/src/index.ts"],
      "@crisp/feedback/contracts": ["./libs/features/feedback/src/contracts.ts"],
      "@crisp/runs": ["./libs/features/runs/src/index.ts"],
      "@crisp/runs/contracts": ["./libs/features/runs/src/contracts.ts"],
      "@crisp/runs/testing": ["./libs/features/runs/src/testing.ts"],
      "@crisp/titling": ["./libs/features/titling/src/index.ts"]
    }
  }
}
